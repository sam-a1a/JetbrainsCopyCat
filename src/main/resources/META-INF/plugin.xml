<idea-plugin>
<id>com.internal.copycat</id>
<name>Copycat</name>
<vendor url="https://github.com/sam-a1a">SamA1A</vendor>

<description><![CDATA[
        Copies file or folder contents to clipboard with powerful formatting options.
    ]]></description>

<depends>com.intellij.modules.platform</depends>

<extensions defaultExtensionNs="com.intellij">
    <toolWindow
            id="CopyCat"
            secondary="false"
            icon="/icons/icon.svg"
            anchor="right"
            factoryClass="com.internal.copycat.CopyCatToolWindowFactory"/>
</extensions>

<actions>
    <action
            id="CopyCat.CopyCatAction"
            class="com.internal.copycat.CopyCatAction"
            text="CopyCat">
        <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
    </action>

    <group
            id="CopyCat.LinesCounterGroup"
            class="com.internal.copycat.CopyCatLinesCounterGroup"
            text="CopyCat Lines Counter"
            popup="true">
        <add-to-group group-id="ProjectViewPopupMenu" anchor="after" relative-to-action="CopyCat.CopyCatAction"/>
    </group>
</actions>

</idea-plugin>